#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    int starting_node;
    cin >> starting_node;

    vector<vector<int>> adjlst(n);

    for (int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;

        adjlst[u].push_back(v);
        adjlst[v].push_back(u);
    }

    vector<int> visited(n, 0);
    queue<int> q;

    q.push(starting_node);
    visited[starting_node] = 1;

    while (!q.empty()) {
        int node = q.front();
        q.pop();

        cout << node << " ";

        for (auto neighbour : adjlst[node]) {
            if (!visited[neighbour]) {
                q.push(neighbour);
                visited[neighbour] = 1;
            }
        }
    }

    return 0;
}
